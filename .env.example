# --- Security ---
# Secret key for session encryption. Change this to a random string.
SECRET_KEY=generate_a_secure_random_string_here

# Access PIN to enter the dashboard.
ACCESS_PIN=1234

# --- App Settings ---
APP_NAME=FileEX
DEBUG=True

# Enforce read-only mode (blocks all DELETE/POST/PUT operations except login)
READ_ONLY=True

# --- Paths ---
# Directory where deleted files/folders and their metadata are stored.
# Relative to the project root or absolute path.
TRASH_DIR=./Trash
